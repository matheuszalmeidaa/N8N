                try:
                    detalhes = api.consultar_detalhes_operacao(
                        op.get('debt_key'),
                        op.get('credit_operation_key')
                    )
                    if detalhes:
                        sucesso += 1
                        registros = processador.processar_operacao_com_historicos(op, detalhes)
                        if registros:
                            com_historico += 1
                            todos_registros.extend(registros)
                        else:
                            sem_historico += 1
                    else:
                        erros += 1
                except Exception:
                    erros += 1
                time.sleep(config.DELAY_ENTRE_REQUESTS)

        print(f"   📊 ✓ {com_historico} com histórico | ○ {sem_historico} sem histórico | ✗ {erros} erros")
        print()

    tempo_total = time.time() - tempo_inicio

    print("="*80)
    print("📊 RESUMO DA EXTRAÇÃO")
    print("="*80)
    print(f"   ⏱️  Tempo total: {tempo_total:.1f} segundos ({tempo_total/60:.1f} minutos)")
    print(f"   📋 Total de operações consultadas (API 1): {total_operacoes}")
    print(f"   📝 Total de registros gerados (com históricos): {len(todos_registros)}")
    print()

    if not todos_registros:
        print("⚠️  Nenhum registro com histórico encontrado")
        cassandra.fechar_conexao()
        return

    df_final = pd.DataFrame(todos_registros)

    # ---------------------------
    # NORMALIZAR CAMPOS NUMÉRICOS
    # ---------------------------
    print("🔢 Normalizando campos numéricos...")
    
    campos_normalizados = []
    for campo in CAMPOS_NUMERICOS:
        if campo in df_final.columns:
            df_final[campo] = df_final[campo].apply(normalizar_numero)
            campos_normalizados.append(campo)
    
    if campos_normalizados:
        print(f"   ✓ {len(campos_normalizados)} campos numéricos normalizados:")
        for i in range(0, len(campos_normalizados), 5):
            print(f"      {', '.join(campos_normalizados[i:i+5])}")
    
    # Mostrar exemplos de valores normalizados
    print("\n   📋 Exemplos de valores normalizados:")
    campos_exemplo = ['val_liquido', 'val_emissao', 'qtd_parcela']
    for campo in campos_exemplo:
        if campo in df_final.columns:
            valores_unicos = df_final[campo].dropna().unique()[:3]
            if len(valores_unicos) > 0:
                print(f"      {campo}: {list(valores_unicos)}")

    # ---------------------------
    # APLICAR TRADUÇÕES
    # ---------------------------
    print("\n🌐 Aplicando traduções...")
    
    if 'credit_type' in df_final.columns:
        df_final['credit_type'] = df_final['credit_type'].apply(
            lambda x: traduzir_campo(x, 'credit_type')
        )
    
    if 'assistance_type' in df_final.columns:
        df_final['assistance_type'] = df_final['assistance_type'].apply(
            lambda x: traduzir_campo(x, 'assistance_type')
        )
    
    if 'dsc_situacao_emprestimo' in df_final.columns:
        df_final['dsc_situacao_emprestimo'] = df_final['dsc_situacao_emprestimo'].apply(
            lambda x: traduzir_campo(x, 'dsc_situacao_emprestimo')
        )
    
    if 'has_insurance' in df_final.columns:
        df_final['has_insurance'] = df_final['has_insurance'].apply(
            lambda x: traduzir_campo(x, 'has_insurance')
        )
    
    if 'marital_status' in df_final.columns:
        df_final['marital_status'] = df_final['marital_status'].apply(
            lambda x: traduzir_campo(x, 'marital_status')
        )
    
    print("   ✓ Traduções aplicadas:")
    print("      - credit_type (tipos de crédito)")
    print("      - assistance_type (tipos de benefício)")
    print("      - dsc_situacao_emprestimo (situações)")
    print("      - has_insurance (Sim/Não)")
    print("      - marital_status (estado civil)")

    # ---------------------------
    # RECOMPUTAR historico_sequencia COM ZERO PADDING
    # ---------------------------
    print("\n🔄 Recalculando sequências de histórico com zero padding...")
    
    if 'historico_event_datetime' in df_final.columns:
        df_final['historico_event_datetime'] = pd.to_datetime(
            df_final['historico_event_datetime'], errors='coerce'
        )

    group_keys = ['debt_key']
    if 'historico_credit_operation_key' in df_final.columns:
        df_final['historico_credit_operation_key'] = df_final['historico_credit_operation_key'].fillna('')
        if df_final['historico_credit_operation_key'].str.strip().replace('', pd.NA).notna().any():
            group_keys = ['debt_key', 'historico_credit_operation_key']

    if 'historico_event_datetime' in df_final.columns:
        sort_asc = [True] * len(group_keys) + [False]
        sort_cols = group_keys + ['historico_event_datetime']
        df_final = df_final.sort_values(sort_cols, ascending=sort_asc).reset_index(drop=True)
    else:
        sort_cols = group_keys.copy()
        if 'historico_id' in df_final.columns:
            sort_cols.append('historico_id')
        df_final = df_final.sort_values(sort_cols).reset_index(drop=True)

    df_final['historico_sequencia_num'] = df_final.groupby(group_keys).cumcount() + 1
    
    max_por_grupo = df_final.groupby(group_keys)['historico_sequencia_num'].transform('max')
    
    def calcular_padding(row):
        max_val = max_por_grupo.iloc[row.name]
        num_digitos = len(str(int(max_val)))
        num_digitos = max(2, num_digitos)
        sequencia = str(int(row['historico_sequencia_num'])).zfill(num_digitos)
        sequencia = sequencia + '*'
        return sequencia
    
    df_final['historico_sequencia'] = df_final.apply(calcular_padding, axis=1)
    
    df_final.drop(columns=['historico_sequencia_num', 'historico_sequencia_tmp'], inplace=True, errors='ignore')
    
    exemplos = df_final['historico_sequencia'].head(15).tolist()
    # ---------------------------
    # Inserir no Cassandra
