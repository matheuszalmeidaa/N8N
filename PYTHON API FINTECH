    if config.USAR_CASSANDRA:
        cassandra.inserir_dados(df_final)

    cassandra.fechar_conexao()

    print("\n" + "="*80)
    print("✅ PROCESSO FINALIZADO COM SUCESSO!")
    print("="*80)


