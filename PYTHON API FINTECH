class GerenciadorCassandra:
    """Gerencia operações com banco de dados Cassandra"""

    def __init__(self, config: Config):
        self.config = config
        self.cluster = None
        self.session = None
        
        if config.USAR_CASSANDRA:
            try:
                if config.CASSANDRA_USERNAME and config.CASSANDRA_PASSWORD:
                    auth_provider = PlainTextAuthProvider(
                        username=config.CASSANDRA_USERNAME,
                        password=config.CASSANDRA_PASSWORD
                    )
                    self.cluster = Cluster([config.CASSANDRA_HOST], auth_provider=auth_provider)
                else:
                    self.cluster = Cluster([config.CASSANDRA_HOST])
                
                self.session = self.cluster.connect()
                self.session.set_keyspace(config.CASSANDRA_KEYSPACE)
                print(f"✅ Conexão com Cassandra estabelecida (keyspace: {config.CASSANDRA_KEYSPACE})")
            except Exception as e:
                print(f"❌ Erro ao conectar no Cassandra: {e}")
                self.session = None

    def limpar_tabela(self):
        """Limpa todos os dados da tabela Cassandra"""
        if not self.session:
            return
        try:
            query = f"TRUNCATE {self.config.CASSANDRA_TABELA}"
            self.session.execute(query)
            print(f"🗑️  Tabela {self.config.CASSANDRA_TABELA} limpa com sucesso no Cassandra")
        except Exception as e:
            print(f"❌ Erro ao limpar tabela Cassandra: {e}")

    def converter_para_texto(self, valor, nome_coluna=None):
        """
        Converte valores para texto, tratando números especialmente
        """
        if valor is None:
            return None
        
        # Se é um campo numérico conhecido, normalizar o número
        if nome_coluna and nome_coluna in CAMPOS_NUMERICOS:
            return normalizar_numero(valor)
        
        # Se é string
        if isinstance(valor, str):
            if valor.strip() == '':
                return None
            return valor
        
        # Se é dict ou list, converter para JSON
        if isinstance(valor, (dict, list)):
            return json.dumps(valor, ensure_ascii=False)
        
        # Tentar detectar se é número mesmo sem estar na lista
        if isinstance(valor, (int, float)):
            return normalizar_numero(valor)
        
        # Outros tipos: converter para string
        valor_str = str(valor)
        
        if valor_str.strip() == '':
            return None
        
        return valor_str

    def converter_tipos_dataframe(self, df: pd.DataFrame) -> pd.DataFrame:
        """
        Converte campos do DataFrame tratando números corretamente
        """
        df_convertido = df.copy()
        
        print("   🔄 Convertendo campos para TEXT (números normalizados)...")
        
        # Processar cada coluna
        for col in df_convertido.columns:
            df_convertido[col] = df_convertido[col].apply(
                lambda x: self.converter_para_texto(x, nome_coluna=col)
            )
        
        return df_convertido

    def inserir_dados(self, df: pd.DataFrame):
        """Insere dados no Cassandra em lotes"""
        if not self.session or df.empty:
            return
        
        try:
            print("🔄 Preparando dados para Cassandra...")
            
            # Mostrar amostra ANTES da conversão
            print("\n📊 AMOSTRA DE DADOS ANTES DA CONVERSÃO:")
            campos_amostra = ['val_liquido', 'val_emissao', 'val_seguro']
            campos_disponiveis = [c for c in campos_amostra if c in df.columns]
            if campos_disponiveis:
                print(df[campos_disponiveis].head(3))
                print(f"\nTipos: {df[campos_disponiveis].dtypes.to_dict()}")
            
            # Converter
            df = self.converter_tipos_dataframe(df)
            
            # Mostrar amostra DEPOIS da conversão
            print("\n📊 AMOSTRA DE DADOS DEPOIS DA CONVERSÃO:")
            if campos_disponiveis:
                print(df[campos_disponiveis].head(3))
                print(f"\nTipos: {df[campos_disponiveis].dtypes.to_dict()}")
            
            colunas = df.columns.tolist()
            placeholders = ', '.join(['?' for _ in colunas])
            colunas_str = ', '.join(colunas)
            query = f"INSERT INTO {self.config.CASSANDRA_TABELA} ({colunas_str}) VALUES ({placeholders})"
            prepared = self.session.prepare(query)
            
            total_registros = len(df)
            registros_inseridos = 0
            
            print(f"\n📤 Inserindo {total_registros} registros no Cassandra em lotes de {self.config.CASSANDRA_TAMANHO_PACOTE}...")
            
            for i in range(0, total_registros, self.config.CASSANDRA_TAMANHO_PACOTE):
                batch = BatchStatement()
                lote_df = df.iloc[i:i + self.config.CASSANDRA_TAMANHO_PACOTE]
                
                for idx, row in lote_df.iterrows():
                    valores = list(row.values)
                    batch.add(prepared, valores)
                
                self.session.execute(batch)
                registros_inseridos += len(lote_df)
                
                if registros_inseridos % (self.config.CASSANDRA_TAMANHO_PACOTE * 5) == 0:
                    print(f"   ... {registros_inseridos}/{total_registros} registros inseridos")
            
            print(f"✅ {registros_inseridos} registros inseridos no Cassandra (tabela: {self.config.CASSANDRA_TABELA})")
            
        except Exception as e:
            print(f"❌ Erro ao inserir dados no Cassandra: {e}")
            import traceback
            traceback.print_exc()

    def fechar_conexao(self):
        """Fecha a conexão com Cassandra"""
        if self.cluster:
            self.cluster.shutdown()
            print("🔌 Conexão com Cassandra encerrada")


