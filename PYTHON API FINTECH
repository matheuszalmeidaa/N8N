def executar_extracao():
    print("="*80)
    print("INICIANDO EXTRAÇÃO DE DADOS - API FINTECH")
    print("="*80)
    print()

    config = Config()

    print("⚙️  MODO DE OPERAÇÃO ATIVO:")
    if config.MODO_CONSULTA == "TESTE":
        print(f"   🧪 TESTE - Consultando apenas o dia {config.DATA_TESTE}")
        print("   (Modo rápido para validar se o sistema está funcionando)")
    elif config.MODO_CONSULTA == "DIA_ESPECIFICO":
        print(f"   📅 DIA ESPECÍFICO - {config.DIA_ESPECIFICO}")
    elif config.MODO_CONSULTA == "MES_ESPECIFICO":
        print(f"   📆 MÊS ESPECÍFICO - {config.MES_ESPECIFICO}")
    elif config.MODO_CONSULTA == "ANO_COMPLETO":
        print(f"   📊 ANO COMPLETO - {config.ANO_COMPLETO}")
    elif config.MODO_CONSULTA == "PERIODO_PERSONALIZADO":
        print(f"   🎯 PERÍODO PERSONALIZADO - {config.DATA_INICIO_PERSONALIZADA} até {config.DATA_FIM_PERSONALIZADA}")

    print(f"   🗄️  Salvar no Cassandra: {'SIM' if config.USAR_CASSANDRA else 'NÃO'}")
    print()

    api = FintechAPI(config)
    processador = ProcessadorDados()
    cassandra = GerenciadorCassandra(config)

    if not api.autenticar():
        print("❌ Falha na autenticação. Abortando.")
        return

    if config.USAR_CASSANDRA and config.LIMPAR_CASSANDRA_ANTES:
        cassandra.limpar_tabela()

    print("📅 Gerando períodos de consulta...")
    df_periodos = processador.gerar_periodos(config)
    print(f"   ✓ {len(df_periodos)} períodos gerados\n")

    if df_periodos.empty:
        print("⚠️  Nenhum período encontrado com os filtros aplicados")
        return

    todos_registros = []
    total_operacoes = 0
    tempo_inicio = time.time()
    print("🔄 Processando dados...\n")

    for idx, periodo in df_periodos.iterrows():
        print(f"📆 [{idx+1}/{len(df_periodos)}] {periodo['data_inicio']} até {periodo['data_fim']} (Lote {periodo['lote']})")

        operacoes = api.consultar_operacoes(periodo['data_inicio'], periodo['data_fim'])
        if not operacoes:
            print("   ⚠️  Nenhuma operação encontrada\n")
            continue

        operacoes_validas = [op for op in operacoes if op.get('cpf')]
        total_operacoes += len(operacoes)
        print(f"   ✓ {len(operacoes_validas)} operações válidas encontradas")

        sucesso = 0
        com_historico = 0
        sem_historico = 0
        erros = 0

        if config.MOSTRAR_PROGRESSO_BARRA:
            pbar = tqdm(operacoes_validas,
                        desc="   📥 Detalhes",
                        unit="op",
                        ncols=100,
                        colour='cyan',
                        bar_format='{desc}: {percentage:3.0f}%|{bar}| {n_fmt}/{total_fmt} [{elapsed}<{remaining}]')
            for op in pbar:
                try:
                    detalhes = api.consultar_detalhes_operacao(
                        op.get('debt_key'),
                        op.get('credit_operation_key')
                    )
                    if detalhes:
                        sucesso += 1
                        registros = processador.processar_operacao_com_historicos(op, detalhes)
                        if registros:
                            com_historico += 1
                            todos_registros.extend(registros)
                        else:
                            sem_historico += 1
                    else:
                        erros += 1
                    pbar.set_postfix_str(f"✓{com_historico} hist | ○{sem_historico} s/hist | ✗{erros} err")
                except Exception:
                    erros += 1
                time.sleep(config.DELAY_ENTRE_REQUESTS)
        else:
            if config.MOSTRAR_LOGS_DETALHADOS:
                print(f"   📥 Consultando detalhes de {len(operacoes_validas)} operações...")
            
            for i, op in enumerate(operacoes_validas, 1):
                if config.MOSTRAR_LOGS_DETALHADOS and i % 50 == 0:
                    print(f"   ... {i}/{len(operacoes_validas)} (✓{com_historico} com hist | ○{sem_historico} sem hist)")

                try:
                    detalhes = api.consultar_detalhes_operacao(
                        op.get('debt_key'),
                        op.get('credit_operation_key')
                    )
                    if detalhes:
                        sucesso += 1
                        registros = processador.processar_operacao_com_historicos(op, detalhes)
                        if registros:
                            com_historico += 1
                            todos_registros.extend(registros)
                        else:
                            sem_historico += 1
                    else:
                        erros += 1
                except Exception:
                    erros += 1
                time.sleep(config.DELAY_ENTRE_REQUESTS)

        print(f"   📊 ✓ {com_historico} com histórico | ○ {sem_historico} sem histórico | ✗ {erros} erros")
        print()

    tempo_total = time.time() - tempo_inicio

    print("="*80)
    print("📊 RESUMO DA EXTRAÇÃO")
    print("="*80)
    print(f"   ⏱️  Tempo total: {tempo_total:.1f} segundos ({tempo_total/60:.1f} minutos)")
    print(f"   📋 Total de operações consultadas (API 1): {total_operacoes}")
    print(f"   📝 Total de registros gerados (com históricos): {len(todos_registros)}")
    print()

    if not todos_registros:
        print("⚠️  Nenhum registro com histórico encontrado")
        cassandra.fechar_conexao()
        return

    df_final = pd.DataFrame(todos_registros)

    # ---------------------------
    # APLICAR TRADUÇÕES E FORMATAÇÕES
    # ---------------------------
    print("🌐 Aplicando traduções e formatações...")
    
    # Traduzir campos
    if 'credit_type' in df_final.columns:
        df_final['credit_type'] = df_final['credit_type'].apply(
            lambda x: traduzir_campo(x, 'credit_type')
        )
    
    if 'assistance_type' in df_final.columns:
        df_final['assistance_type'] = df_final['assistance_type'].apply(
            lambda x: traduzir_campo(x, 'assistance_type')
        )
    
    if 'dsc_situacao_emprestimo' in df_final.columns:
        df_final['dsc_situacao_emprestimo'] = df_final['dsc_situacao_emprestimo'].apply(
            lambda x: traduzir_campo(x, 'dsc_situacao_emprestimo')
        )
    
    if 'has_insurance' in df_final.columns:
        df_final['has_insurance'] = df_final['has_insurance'].apply(
            lambda x: traduzir_campo(x, 'has_insurance')
        )
    
    if 'marital_status' in df_final.columns:
        df_final['marital_status'] = df_final['marital_status'].apply(
            lambda x: traduzir_campo(x, 'marital_status')
        )
    
    # Formatar valores monetários para padrão brasileiro (1.000,02)
    campos_monetarios = ['val_emissao', 'val_liquido', 'val_seguro','first_installment_value']
    for campo in campos_monetarios:
        if campo in df_final.columns:
            df_final[campo] = df_final[campo].apply(formatar_valor_monetario)
    
    print("   ✓ Traduções aplicadas:")
    print("      - credit_type (tipos de crédito)")
    print("      - assistance_type (tipos de benefício)")
    print("      - dsc_situacao_emprestimo (situações)")
    print("      - has_insurance (Sim/Não)")
    print("      - marital_status (estado civil)")
    print("   ✓ Valores formatados: val_emissao, val_liquido, val_seguro (formato: 1.000,02)")

    # ---------------------------
    # RECOMPUTAR historico_sequencia POR PROPOSTA COM ZERO PADDING
    # ---------------------------
    print("🔄 Recalculando sequências de histórico com zero padding...")
    
    if 'historico_event_datetime' in df_final.columns:
        df_final['historico_event_datetime'] = pd.to_datetime(
            df_final['historico_event_datetime'], errors='coerce'
        )

    group_keys = ['debt_key']
    if 'historico_credit_operation_key' in df_final.columns:
        df_final['historico_credit_operation_key'] = df_final['historico_credit_operation_key'].fillna('')
        if df_final['historico_credit_operation_key'].str.strip().replace('', pd.NA).notna().any():
            group_keys = ['debt_key', 'historico_credit_operation_key']

    if 'historico_event_datetime' in df_final.columns:
        sort_asc = [True] * len(group_keys) + [False]
        sort_cols = group_keys + ['historico_event_datetime']
        df_final = df_final.sort_values(sort_cols, ascending=sort_asc).reset_index(drop=True)
    else:
        sort_cols = group_keys.copy()
        if 'historico_id' in df_final.columns:
            sort_cols.append('historico_id')
        df_final = df_final.sort_values(sort_cols).reset_index(drop=True)

    df_final['historico_sequencia_num'] = df_final.groupby(group_keys).cumcount() + 1
    
    max_por_grupo = df_final.groupby(group_keys)['historico_sequencia_num'].transform('max')
    
    def calcular_padding(row):
        max_val = max_por_grupo.iloc[row.name]
        num_digitos = len(str(int(max_val)))
        num_digitos = max(2, num_digitos)
        sequencia = str(int(row['historico_sequencia_num'])).zfill(num_digitos)
        sequencia = sequencia + '*'
        return sequencia
    
    df_final['historico_sequencia'] = df_final.apply(calcular_padding, axis=1)
    
    df_final.drop(columns=['historico_sequencia_num', 'historico_sequencia_tmp'], inplace=True, errors='ignore')
    
    exemplos = df_final['historico_sequencia'].head(15).tolist()
    print(f"   📋 Exemplos de sequências geradas: {exemplos}")
    print(f"   ⭐ Asterisco (*) em todos os registros para garantir ordenação correta no BI")
    
    print(f"   ✓ Sequências recalculadas (formato: 01*, 02*, 03*... para melhor compatibilidade com BI)")

    # ---------------------------
    # Inserir no Cassandra
    # ---------------------------
    if config.USAR_CASSANDRA:
        cassandra.inserir_dados(df_final)

    cassandra.fechar_conexao()

    print("\n✅ Processo finalizado com sucesso!")
    print("📝 Resumo das transformações aplicadas:")
    print("   ✓ Campos traduzidos para português")
    print("   ✓ Valores monetários no formato brasileiro (1.000,02)")
    print("   ✓ Sequências com zero padding e asterisco para ordenação")

if __name__ == "__main__":
    executar_extracao()
