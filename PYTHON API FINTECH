def traduzir_campo(valor, tipo_campo):
    """Traduz um valor usando o dicionário apropriado"""
    if valor is None or pd.isna(valor):
        return valor
    
    valor_str = str(valor).strip()
    
    if tipo_campo in TRADUCOES:
        return TRADUCOES[tipo_campo].get(valor_str, valor)
    
    return valor


def normalizar_numero(valor):
    """
    Converte qualquer valor numérico para string com ponto decimal (padrão internacional)
    Exemplos:
        1643.06 → "1643.06"
        "1.643,06" → "1643.06"
        1643 → "1643"
        None → None
    """
    if valor is None or pd.isna(valor):
        return None
    
    # Se já é número (int ou float)
    if isinstance(valor, (int, float)):
        # Converter para string mantendo ponto decimal
        if isinstance(valor, int):
            return str(valor)
        else:
            # Float: remover trailing zeros desnecessários
            valor_str = f"{valor:.10f}".rstrip('0').rstrip('.')
            return valor_str
    
    # Se é string
    if isinstance(valor, str):
        valor = valor.strip()
        
        # Se está vazio
        if valor == '':
            return None
        
        # Se está no formato brasileiro (1.643,06)
        if ',' in valor:
            # Remover pontos de milhar e trocar vírgula por ponto
            valor = valor.replace('.', '').replace(',', '.')
        
        # Tentar converter para float e depois para string
        try:
            valor_float = float(valor)
            if valor_float == int(valor_float):
                return str(int(valor_float))
            else:
                # Remover trailing zeros
                valor_str = f"{valor_float:.10f}".rstrip('0').rstrip('.')
                return valor_str
        except (ValueError, TypeError):
            # Se não conseguir converter, retornar original
            return valor
    
    # Outros tipos: converter para string
    return str(valor)


