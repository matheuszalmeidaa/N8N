                        sucesso += 1
                        registros = processador.processar_operacao_com_historicos(op, detalhes)
                        if registros:
                            com_historico += 1
                            todos_registros.extend(registros)
                        else:
                            sem_historico += 1
                    else:
                        erros += 1
                    pbar.set_postfix_str(f"✓{com_historico} hist | ○{sem_historico} s/hist | ✗{erros} err")
