def traduzir_campo(valor, tipo_campo):
    """Traduz um valor usando o dicionário apropriado"""
    if valor is None or pd.isna(valor):
        return valor
    
    # Converter para string para comparação
    valor_str = str(valor).strip()
    
    if tipo_campo in TRADUCOES:
        return TRADUCOES[tipo_campo].get(valor_str, valor)
    
    return valor


def formatar_valor_monetario(valor):
    """
    Converte valor numérico para formato brasileiro: 1.000,02
    Mantém como string para preservar formatação no Cassandra
    """
    if valor is None or pd.isna(valor):
        return None
    
    try:
        # Converter para float primeiro
        if isinstance(valor, str):
            # Remove espaços e troca vírgula por ponto se necessário
            valor = valor.replace(' ', '').replace(',', '.')
        
        valor_float = float(valor)
        
        # Formatar no padrão brasileiro
        valor_formatado = f"{valor_float:,.2f}".replace(',', 'X').replace('.', ',').replace('X', '.')
        
        return valor_formatado
    except (ValueError, TypeError):
        return valor


