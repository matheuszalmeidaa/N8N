                    erros += 1
                time.sleep(config.DELAY_ENTRE_REQUESTS)
        else:
            if config.MOSTRAR_LOGS_DETALHADOS:
                print(f"   📥 Consultando detalhes de {len(operacoes_validas)} operações...")
            
            for i, op in enumerate(operacoes_validas, 1):
                if config.MOSTRAR_LOGS_DETALHADOS and i % 50 == 0:
