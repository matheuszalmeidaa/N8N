    {
      "parameters": {
        "jsCode": "// Processa todos os itens recebidos do Google Sheets\nconst items = $input.all();\n\n// 🎯 Pega a cidade que está sendo processada no fluxo atual\nconst cidadeAtual = $('Remove Duplicates').first().json.Cidade;\n\n// 🔹 Filtra apenas os itens da cidade atual\nconst itemsFiltrados = items.filter(item => {\n  const cidadeItem = item.json.Cidade;\n  return cidadeItem === cidadeAtual;\n});\n\n// Inicializa contadores\nlet totalRegistros = 0;\nlet totalEnviados = 0;\nlet totalErros = 0;\nlet listaErros = [];\n\n// Categorias de erro\nlet errosCaracteresInvalidos = 0;\nlet errosComprimento = 0;\nlet errosDDI = 0;\nlet errosOutros = 0;\n\n// Função para validar formato do número\nfunction validarNumero(contato) {\n  const contatoStr = String(contato || '').trim();\n  const problemas = [];\n  \n  const numeroLimpo = contatoStr.replace(/\\s/g, '');\n  \n  if (contatoStr.includes('+')) {\n    problemas.push('Contém \"+\"');\n  }\n  if (contatoStr.includes('(') || contatoStr.includes(')')) {\n    problemas.push('Contém \"()\"');\n  }\n  if (contatoStr.includes('-')) {\n    problemas.push('Contém \"-\"');\n  }\n  \n  if (!/^\\d+$/.test(numeroLimpo)) {\n    problemas.push('Caracteres inválidos');\n  }\n  \n  const tamanho = numeroLimpo.length;\n  if (tamanho < 12) {\n    problemas.push(tamanho + ' dígitos (esperado 12-13)');\n  } else if (tamanho > 13) {\n    problemas.push(tamanho + ' dígitos (esperado 12-13)');\n  }\n  \n  if (!numeroLimpo.startsWith('55')) {\n    problemas.push('Sem código 55');\n  }\n  \n  return {\n    valido: problemas.length === 0,\n    problemas: problemas\n  };\n}\n\n// Processa cada item FILTRADO\nitemsFiltrados.forEach(item => {\n  const row = item.json;\n  const status = String(row['Enviados?'] || '').trim();\n  const contato = row.Contato || '';\n  const motivoValidacao = row.motivo_validacao || '';\n  \n  totalRegistros++;\n  \n  // 🔹 Verifica se foi ENVIADO (única condição de sucesso)\n  if (status.toLowerCase() === 'enviado') {\n    totalEnviados++;\n  } \n  // 🔹 Qualquer outra coisa que não seja \"Enviado\" OU campo vazio é considerado ERRO\n  else if (status !== '') {\n    totalErros++;\n    \n    let categoriaErro = '';\n    let descricaoErro = status;\n    \n    // Categoriza pelo conteúdo do status\n    if (status.includes('caracteres não numéricos')) {\n      errosCaracteresInvalidos++;\n      categoriaErro = '🔤 Caracteres inválidos';\n      descricaoErro = status;\n    } else if (status.includes('comprimento incorreto')) {\n      errosComprimento++;\n      categoriaErro = '📏 Tamanho incorreto';\n      descricaoErro = status;\n    } else if (status.includes('não inicia com DDI') || status.includes('não inicia com')) {\n      errosDDI++;\n      categoriaErro = '🌍 DDI/DDD incorreto';\n      descricaoErro = status;\n    } else if (status.toLowerCase().includes('erro')) {\n      errosOutros++;\n      categoriaErro = '❌ Erro no envio';\n      descricaoErro = status;\n    } else {\n      // Qualquer outro status não reconhecido\n      errosOutros++;\n      categoriaErro = '⚠️ Outro erro';\n      descricaoErro = status;\n    }\n    \n    const analiseNumero = validarNumero(contato);\n    \n    listaErros.push({\n      linha: row.row_number,\n      nome: row.Nome,\n      contato: contato,\n      erro: descricaoErro,\n      categoria: categoriaErro,\n      problemasNumero: analiseNumero.problemas,\n      numeroInvalido: !analiseNumero.valido\n    });\n  }\n});\n\n// Calcula a porcentagem de acerto\nconst porcentagemAcerto = totalRegistros > 0 \n  ? ((totalEnviados / totalRegistros) * 100).toFixed(2) \n  : 0;\nconst porcentagemErro = totalRegistros > 0 \n  ? ((totalErros / totalRegistros) * 100).toFixed(2) \n  : 0;\n\n// Data e hora atual formatada\nconst agora = new Date();\nconst dataHora = agora.toLocaleString('pt-BR', {\n  timeZone: 'America/Bahia',\n  day: '2-digit',\n  month: '2-digit',\n  year: 'numeric',\n  hour: '2-digit',\n  minute: '2-digit'\n});\n\n// Monta a mensagem do relatório\nlet mensagemRelatorio = '📅 *Disparo ' + cidadeAtual + ' — Armazém do Queijo*\\n';\nmensagemRelatorio += '✅ *Fluxo concluído com sucesso!*\\n\\n';\nmensagemRelatorio += '🕐 Finalizado em: ' + dataHora + '\\n\\n';\nmensagemRelatorio += '━━━━━━━━━━━━━━━━━━━\\n';\nmensagemRelatorio += '📊 *ESTATÍSTICAS DO ENVIO*\\n';\nmensagemRelatorio += '━━━━━━━━━━━━━━━━━━━\\n\\n';\nmensagemRelatorio += '📋 Total de contatos: *' + totalRegistros + '*\\n';\nmensagemRelatorio += '✅ Enviados: *' + totalEnviados + '* (' + porcentagemAcerto + '%)\\n';\nmensagemRelatorio += '❌ Erros: *' + totalErros + '* (' + porcentagemErro + '%)\\n\\n';\n\n// Adiciona apenas contagem de erros se houver\nif (totalErros > 0) {\n  if (errosCaracteresInvalidos > 0) {\n    mensagemRelatorio += '🔤 Caracteres inválidos: *' + errosCaracteresInvalidos + '*\\n';\n  }\n  if (errosComprimento > 0) {\n    mensagemRelatorio += '📏 Tamanho incorreto: *' + errosComprimento + '*\\n';\n  }\n  if (errosDDI > 0) {\n    mensagemRelatorio += '🌍 DDI/DDD incorreto: *' + errosDDI + '*\\n';\n  }\n  if (errosOutros > 0) {\n    mensagemRelatorio += '⚠️ Outros erros: *' + errosOutros + '*\\n';\n  }\n  mensagemRelatorio += '\\n';\n} else {\n  mensagemRelatorio += '🎉 *Todos os envios concluídos!*\\n\\n';\n}\n\nmensagemRelatorio += '━━━━━━━━━━━━━━━━━━━';\n\nreturn [\n  {\n    json: {\n      cidadeProcessada: cidadeAtual,\n      totalRegistros: totalRegistros,\n      totalEnviados: totalEnviados,\n      totalErros: totalErros,\n      porcentagemAcerto: parseFloat(porcentagemAcerto),\n      porcentagemErro: parseFloat(porcentagemErro),\n      errosPorCategoria: {\n        caracteresInvalidos: errosCaracteresInvalidos,\n        comprimento: errosComprimento,\n        ddi: errosDDI,\n        outros: errosOutros\n      },\n      listaErros: listaErros,\n      mensagemRelatorio: mensagemRelatorio,\n      dataHoraFinalizacao: dataHora,\n      timestamp: new Date().toISOString()\n    }\n  }\n];"
      },
